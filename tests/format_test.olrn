struct Point { x: i64, y: i64 }

fn add(a: i64, b: i64) -> i64
{
    ret a + b
}

fn main() -> void
{
    p := Point{.x=2, .y=3}
    nums :[]i64 = {10, 20, 30}
    n :^i64 = @alo(i64)
    n.^ = 99

    @pf("expr {p.x + p.y} call {add(4, 5)} index {nums[1]} ptr {n.^}\n")
    @pf("pos {} {}\n", p.x, add(6, 7))
    @pf("braces {{ok}}\n")

    fmt := "stored {} {}\n"
    @pf(fmt, p.y, add(1, 2))

    named := "stored named {p.x}\n"
    @pf(named)
}

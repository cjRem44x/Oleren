import (
    std = @libs.std,
)

fn main() -> void
{
    # write a temp file
    wf :File = io_open("/tmp/olrn_io_test.txt", IOMode.Write)
    data :[]u8 = {72, 101, 108, 108, 111, 10}  # "Hello\n"
    io_write(wf, data)
    io_close(wf)

    # read it back line by line
    rf :File = io_open("/tmp/olrn_io_test.txt", IOMode.Read)
    line :str = io_readline(rf)
    @pl(line)

    # seek back and check tell
    io_seek(rf, 0, SeekFrom.Start)
    pos :i64 = io_tell(rf)
    @pl(pos)

    io_close(rf)
}

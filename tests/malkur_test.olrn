@import (
    mk = @std.malkur,
)

# headless-safe malkur test: pure math/color/collision only — no window,
# so it runs under make test. Window/draw/input paths need a display.
fn main() -> void
{
    # vec2 math
    a :: mk.vec2(3.0, 4.0)
    @pl(mk.v2_len(a))                                    # 5
    b :: mk.v2_add(a, mk.vec2(1.0, 2.0))
    @pl(b.x)                                             # 4
    @pl(b.y)                                             # 6
    @pl(mk.v2_dot(a, mk.vec2(2.0, 0.5)))                 # 8
    n :: mk.v2_norm(a)
    @pl(n.x)                                             # 0.6
    @pl(mk.v2_dist(mk.vec2_zero(), mk.vec2(3.0, 4.0)))   # 5
    m :: mk.v2_lerp(mk.vec2_zero(), mk.vec2(10.0, 20.0), 0.5)
    @pl(m.x)                                             # 5
    @pl(m.y)                                             # 10

    # colors
    c :: mk.rgba(10, 20, 30, 255)
    @pl(@i32(c.r))                                       # 10
    @pl(@i32(c.g))                                       # 20
    faded :: mk.color_fade(mk.WHITE, 0.5)
    @pl(@i32(faded.a))                                   # 127
    mid :: mk.color_lerp(mk.BLACK, mk.WHITE, 0.5)
    @pl(@i32(mid.r))                                     # 127

    # collision
    r1 :: mk.rect(0.0, 0.0, 10.0, 10.0)
    r2 :: mk.rect(5.0, 5.0, 10.0, 10.0)
    @pl(mk.check_rects(r1, r2))                          # true
    @pl(mk.check_point_rect(mk.vec2(2.0, 2.0), r1))      # true
    @pl(mk.check_circles(mk.vec2_zero(), 3.0, mk.vec2(5.0, 0.0), 1.0))  # false
    ix :: mk.rect_intersect(r1, r2)
    @pl(ix.w)                                            # 5
    @pl(ix.x)                                            # 5

    # enums through the alias
    @pl(mk.keys.SPACE)                                   # 44
    @pl(mk.mbtn.LEFT)                                    # 1
}

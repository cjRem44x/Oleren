err FileError { NotFound, PermDenied }
err NetError  { Timeout, Refused }

fn read_file(path: str) -> !str
{
    if path == "" {
        ret err.BadPath
    }
    if path == "missing" {
        ret FileError.NotFound
    }
    ret "hello from file"
}

fn connect(host: str) -> !i32
{
    if host == "" {
        ret NetError.Refused
    }
    ret 42
}

# errdefer: runs only when the scope exits with an error, LIFO after defer
fn cleanup_demo(fail: bool) -> !i32
{
    errdefer @pl("errdefer ran")
    defer @pl("defer ran")
    if fail { ret err.Boom }
    ret 1
}

fn do_work() -> !void
{
    v1 := try cleanup_demo(false)    # defer only
    @pl(v1)
    v2 := cleanup_demo(true) catch 0 # defer, then errdefer
    @pl(v2)

    content := try read_file("myfile.txt")
    @pl(content)

    n := connect("localhost") catch 0
    @pl(n)

    size := read_file("missing") catch |e| {
        @pl(e.msg)
        ret err.Wrapped
    }
    @pl(size)
}

fn main() -> !void
{
    do_work() catch |e| {
        @pl("main caught error:")
        @pl(e.msg)
    }
}

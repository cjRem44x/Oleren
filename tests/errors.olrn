err FileError { NotFound, PermDenied }
err NetError  { Timeout, Refused }

fn read_file(path: str) -> !str
{
    if path == "" {
        ret err.BadPath
    }
    if path == "missing" {
        ret FileError.NotFound
    }
    ret "hello from file"
}

fn connect(host: str) -> !i32
{
    if host == "" {
        ret NetError.Refused
    }
    ret 42
}

# named error set: ret and try must stay within the declared set
err ParseError { BadFormat, OutOfRange }

fn digit(s: str) -> ParseError!i32
{
    n := @i32(s) catch |e| { ret ParseError.BadFormat }
    if n < 0 or n > 9 { ret ParseError.OutOfRange }
    ret n
}

fn first_digit(s: str) -> ParseError!i32
{
    ret try digit(s)
}

# errdefer: runs only when the scope exits with an error, LIFO after defer
fn cleanup_demo(fail: bool) -> !i32
{
    errdefer @pl("errdefer ran")
    defer @pl("defer ran")
    if fail { ret err.Boom }
    ret 1
}

fn do_work() -> !void
{
    v1 := try cleanup_demo(false)    # defer only
    @pl(v1)
    v2 := cleanup_demo(true) catch 0 # defer, then errdefer
    @pl(v2)

    # fallible string casts — @i32(str) returns !i32
    parsed := try @i32("42")
    @pl(parsed)                      # 42
    @pl(@i32("abc") catch -1)        # -1
    @pl(@i32("12x") catch -2)        # -2 (trailing garbage rejected)
    @pl(@u32("-5") catch 7)          # 7  (negative into unsigned rejected)
    f := try @f64("3.14")
    @pl(f)                           # 3.14
    @pl(@i32(3.9))                   # 3 (numeric casts stay plain)

    # named-set fns
    d := try first_digit("5")
    @pl(d)                           # 5
    bad := first_digit("99") catch -9
    @pl(bad)                         # -9 (OutOfRange swallowed)

    content := try read_file("myfile.txt")
    @pl(content)

    n := connect("localhost") catch 0
    @pl(n)

    size := read_file("missing") catch |e| {
        @pl(e.msg)
        ret err.Wrapped
    }
    @pl(size)
}

fn main() -> !void
{
    do_work() catch |e| {
        @pl("main caught error:")
        @pl(e.msg)
    }
}

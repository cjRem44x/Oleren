# gdev — Oleren gamedev library (SDL2 backend)
# Import explicitly: mk :: @std.gdev  (or  mk = @std.gdev  in @import)
# Types Color, Vec2, Rect come from the C++ backend.

err GdevError { InitFailed, LoadFailed, AudioFailed }

type Texture = i64
type Sound   = i64
type Music   = i64
type Font    = i64

# SDL scancodes
enum keys => i32 {
    A=4,  B=5,  C=6,  D=7,  E=8,  F=9,  G=10, H=11, I=12, J=13,
    K=14, L=15, M=16, N=17, O=18, P=19, Q=20, R=21, S=22, T=23,
    U=24, V=25, W=26, X=27, Y=28, Z=29,
    N1=30, N2=31, N3=32, N4=33, N5=34, N6=35, N7=36, N8=37, N9=38, N0=39,
    ENTER=40, ESCAPE=41, BACKSPACE=42, TAB=43, SPACE=44,
    F1=58, F2=59, F3=60, F4=61, F5=62,  F6=63,
    F7=64, F8=65, F9=66, F10=67, F11=68, F12=69,
    RIGHT=79, LEFT=80, DOWN=81, UP=82,
    LCTRL=224, LSHIFT=225, LALT=226, RCTRL=228, RSHIFT=229, RALT=230,
}

# SDL mouse button numbers
enum mbtn => i32 { LEFT=1, MIDDLE=2, RIGHT=3 }

# built-in palette — mk.NAME
BLACK       :Color: Color{.r=0,   .g=0,   .b=0,   .a=255}
WHITE       :Color: Color{.r=255, .g=255, .b=255, .a=255}
RED         :Color: Color{.r=230, .g=41,  .b=55,  .a=255}
GREEN       :Color: Color{.r=0,   .g=228, .b=48,  .a=255}
BLUE        :Color: Color{.r=0,   .g=121, .b=241, .a=255}
YELLOW      :Color: Color{.r=253, .g=249, .b=0,   .a=255}
ORANGE      :Color: Color{.r=255, .g=161, .b=0,   .a=255}
PURPLE      :Color: Color{.r=200, .g=122, .b=255, .a=255}
PINK        :Color: Color{.r=255, .g=109, .b=194, .a=255}
GRAY        :Color: Color{.r=130, .g=130, .b=130, .a=255}
DARKGRAY    :Color: Color{.r=80,  .g=80,  .b=80,  .a=255}
TRANSPARENT :Color: Color{.r=0,   .g=0,   .b=0,   .a=0}


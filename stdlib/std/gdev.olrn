}

fn gdev_pad_btn_release(id: i32, btn: i32) -> bool
{
    ret _olrn_gd_pad_btn_released(id, btn)
}

fn gdev_pad_axis(id: i32, axis: i32) -> f32
{
    ret _olrn_gd_pad_axis(id, axis)
}

fn gdev_pad_axis_dz(id: i32, axis: i32, dz: f32) -> f32
{
    v :: _olrn_gd_pad_axis(id, axis)
    if v > -dz and v < dz { ret 0.0 }
    ret v
}


# ── color helpers (pure Oleren) ─────────────────────────────────

fn gdev_rgba(r: i32, g: i32, b: i32, a: i32) -> Color
{
    ret Color{.r=@u8(r), .g=@u8(g), .b=@u8(b), .a=@u8(a)}
}

fn gdev_color_fade(c: Color, alpha: f32) -> Color
{
    a :: math_clamp(@f64(alpha), 0.0, 1.0)
    ret Color{.r=c.r, .g=c.g, .b=c.b, .a=@u8(@f64(255.0) * a)}
}

fn gdev_color_lerp(a: Color, b: Color, t: f32) -> Color
{
    k :: math_clamp(@f64(t), 0.0, 1.0)
    ret Color{
        .r=@u8(@f64(a.r) + (@f64(b.r) - @f64(a.r)) * k),
        .g=@u8(@f64(a.g) + (@f64(b.g) - @f64(a.g)) * k),
        .b=@u8(@f64(a.b) + (@f64(b.b) - @f64(a.b)) * k),
        .a=@u8(@f64(a.a) + (@f64(b.a) - @f64(a.a)) * k),
    }
}

# ── Vec2 math (pure Oleren) ─────────────────────────────────────

fn gdev_vec2(x: f32, y: f32) -> Vec2
{
    ret Vec2{.x=x, .y=y}
}

fn gdev_vec2_zero() -> Vec2
{
    ret Vec2{.x=0.0, .y=0.0}
}

fn gdev_rect(x: f32, y: f32, w: f32, h: f32) -> Rect
{
    ret Rect{.x=x, .y=y, .w=w, .h=h}
}

fn gdev_v2_add(a: Vec2, b: Vec2) -> Vec2
{
    ret Vec2{.x=a.x+b.x, .y=a.y+b.y}
}

fn gdev_v2_sub(a: Vec2, b: Vec2) -> Vec2
{
    ret Vec2{.x=a.x-b.x, .y=a.y-b.y}
}

fn gdev_v2_scale(v: Vec2, s: f32) -> Vec2
{
    ret Vec2{.x=v.x*s, .y=v.y*s}
}

fn gdev_v2_dot(a: Vec2, b: Vec2) -> f32
{
    ret a.x*b.x + a.y*b.y
}

fn gdev_v2_len(v: Vec2) -> f32
{
    ret @f32(math_sqrt(@f64(v.x*v.x + v.y*v.y)))
}

fn gdev_v2_dist(a: Vec2, b: Vec2) -> f32
{
    dx :: a.x - b.x
    dy :: a.y - b.y
    ret @f32(math_sqrt(@f64(dx*dx + dy*dy)))
}

fn gdev_v2_norm(v: Vec2) -> Vec2
{
    l :: gdev_v2_len(v)
    if l == 0.0 { ret Vec2{.x=0.0, .y=0.0} }
    ret Vec2{.x=v.x/l, .y=v.y/l}
}

fn gdev_v2_lerp(a: Vec2, b: Vec2, t: f32) -> Vec2
{
    ret Vec2{.x=a.x + (b.x-a.x)*t, .y=a.y + (b.y-a.y)*t}
}

# ── 2D collision (pure Oleren) ──────────────────────────────────

fn gdev_check_rects(a: Rect, b: Rect) -> bool
{
    ret a.x < b.x+b.w and a.x+a.w > b.x and a.y < b.y+b.h and a.y+a.h > b.y
}

fn gdev_check_circles(c1: Vec2, r1: f32, c2: Vec2, r2: f32) -> bool
{
    ret gdev_v2_dist(c1, c2) <= r1 + r2
}

fn gdev_check_point_rect(pt: Vec2, r: Rect) -> bool
{
    ret pt.x >= r.x and pt.x <= r.x+r.w and pt.y >= r.y and pt.y <= r.y+r.h
}

fn gdev_check_point_circle(pt: Vec2, center: Vec2, r: f32) -> bool
{
    ret gdev_v2_dist(pt, center) <= r
}

fn gdev_rect_intersect(a: Rect, b: Rect) -> Rect
{
    x1 :: @f32(math_max(@f64(a.x), @f64(b.x)))
    y1 :: @f32(math_max(@f64(a.y), @f64(b.y)))
    x2 :: @f32(math_min(@f64(a.x+a.w), @f64(b.x+b.w)))
    y2 :: @f32(math_min(@f64(a.y+a.h), @f64(b.y+b.h)))
    if x2 <= x1 or y2 <= y1 { ret Rect{.x=0.0, .y=0.0, .w=0.0, .h=0.0} }
    ret Rect{.x=x1, .y=y1, .w=x2-x1, .h=y2-y1}
}

# ── gamepad ─────────────────────────────────────────────────────

# SDL GameController button indices
enum pad_btn => i32 {
    A=0, B=1, X=2, Y=3,
    BACK=4, GUIDE=5, START=6,
    LS=7, RS=8,
    LB=9, RB=10,
    UP=11, DOWN=12, LEFT=13, RIGHT=14,
}

# SDL GameController axis indices
enum pad_axis => i32 {
    LEFTX=0, LEFTY=1,
    RIGHTX=2, RIGHTY=3,
    LT=4, RT=5,
}


# ── color from packed u32 (RRGGBBAA) ────────────────────────────

fn gdev_hex(val: u32) -> Color
{
    r :: @u8((val >> 24) & 255)
    g :: @u8((val >> 16) & 255)
    b :: @u8((val >> 8) & 255)
    a :: @u8(val & 255)
    ret Color{.r=r, .g=g, .b=b, .a=a}
}

For basic encryptions,

```
import(
    std = @libs.std,
)

fn main() -> !void
{
    s :str = "HelloWorld"
    defer @free(s)
    secret := try std.crypto.pkhash(s) # Private Key Password Hashing takes str and returns str
    defer @free(secret)

    @pl(secret)

    isAuth := try std.crypto.pkhash_auth(secret, "HelloWorld") # returns bool
    @pl(isAuth)

    try std.crypto.enc_file(path_to_file: str, pk: str)

    try std.crypto.dec_file(path_to_file: str, pk: str)
}
```
